{
  "name": "awesome-multimodal-world-reasoning",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://romgai.github.io/awesome-multimodal-world-reasoning/",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "data": "node scripts/generate-portal-data.mjs",
    "dev": "node scripts/generate-portal-data.mjs && node scripts/run-vinext.mjs dev",
    "build": "node scripts/generate-portal-data.mjs && node scripts/run-vinext.mjs build",
    "start": "node scripts/run-vinext.mjs start",
    "validate": "node scripts/generate-portal-data.mjs && node scripts/validate-curation.mjs",
    "links": "node scripts/generate-portal-data.mjs && python scripts/check-links.py",
    "test": "node scripts/generate-portal-data.mjs && node --test tests/catalog.test.mjs && node scripts/validate-curation.mjs && node scripts/run-vinext.mjs build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
